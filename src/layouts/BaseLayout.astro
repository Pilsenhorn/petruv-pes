---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Chovatelská stanice Griffon" } = Astro.props;
---

<!DOCTYPE html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body class="bg-white text-neutral-900">
    <slot />
  </body>
</html>